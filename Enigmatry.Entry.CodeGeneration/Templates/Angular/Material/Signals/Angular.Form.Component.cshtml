@using Enigmatry.Entry.CodeGeneration
@using Enigmatry.Entry.CodeGeneration.Angular
@using Enigmatry.Entry.CodeGeneration.Configuration
@using Enigmatry.Entry.CodeGeneration.Configuration.Form.Controls
@using Enigmatry.Entry.CodeGeneration.Configuration.Form.Controls.Array
@using Enigmatry.Entry.CodeGeneration.Templates.HtmlHelperExtensions.Angular
@using Enigmatry.Entry.CodeGeneration.Templates.HtmlHelperExtensions.TypeScript
@model Enigmatry.Entry.CodeGeneration.Configuration.Form.FormComponentModel;
@inject CodeGeneratorOptions Options;
import { ChangeDetectionStrategy, Component, DestroyRef, effect, inject, LOCALE_ID, signal, TemplateRef } from '@@angular/core';
import { toSignal } from '@@angular/core/rxjs-interop';
import { input, model, output } from '@@angular/core';
import { FormArray, FormControl, FormGroup, ReactiveFormsModule, Validators } from '@@angular/forms';
import { I@(Model.ComponentInfo.ModelType) } from '@Options.ApiClientTsImportPath';
@{
    var entryFormImports = "IFieldExpressionDictionary, IFieldPropertyExpressionDictionary, SelectConfiguration, sortOptions";
    if (Model.HasAnyAsyncValidators()) entryFormImports += ", ENTRY_ASYNC_VALIDATOR_RESOLVER";
}
import { @Html.Raw(entryFormImports) } from '@@enigmatry/entry-form';
@if (Model.FormControlsOfType<SelectControlBase>().Any(s => s.Options.HasDynamicValues))
{
@:import { Observable } from 'rxjs';
}

@@Component({
  selector: '@Model.AngularComponentSelector(Options.GeneratedComponentPrefix)',
  imports: [ReactiveFormsModule],
  templateUrl: './@(Model.AngularComponentFileName()).html',
  changeDetection: ChangeDetectionStrategy.OnPush
})
export class @Model.AngularComponentName() {
    protected readonly isReadonly = input@(Html.Raw("<boolean>"))(false);
    protected readonly model = model@(Html.Raw($"<I{Model.ComponentInfo.ModelType}>"))({} as I@(Model.ComponentInfo.ModelType));
    protected readonly saveButtonText = input@(Html.Raw("<string>"))('Save');
    protected readonly cancelButtonText = input@(Html.Raw("<string>"))('Cancel');
    protected readonly saveButtonDisabled = input@(Html.Raw("<boolean>"))(false);
    protected readonly formButtonsTemplate = input@(Html.Raw("<TemplateRef<unknown> | null | undefined>"))();

    protected readonly fieldsHideExpressions = input@(Html.Raw($"<IFieldExpressionDictionary<I{Model.ComponentInfo.ModelType}> | undefined>"))();
    protected readonly fieldsLabelExpressions = input@(Html.Raw($"<IFieldPropertyExpressionDictionary<I{Model.ComponentInfo.ModelType}> | undefined>"))();
    protected readonly fieldsPropertyExpressions = input@(Html.Raw($"<IFieldPropertyExpressionDictionary<I{Model.ComponentInfo.ModelType}> | undefined>"))();
    protected readonly fieldsDisableExpressions = input@(Html.Raw($"<IFieldExpressionDictionary<I{Model.ComponentInfo.ModelType}> | undefined>"))();
    protected readonly fieldsRequiredExpressions = input@(Html.Raw($"<IFieldExpressionDictionary<I{Model.ComponentInfo.ModelType}> | undefined>"))();

@Html.AllSelectInputDeclarations(Model, Options.EnableI18N)
    protected readonly save = output@(Html.Raw($"<I{Model.ComponentInfo.ModelType}>"))();
    protected readonly cancel = output@(Html.Raw("<void>"))();
    protected readonly buttonClick = output@(Html.Raw("<string>"))();

    private readonly destroyRef = inject(DestroyRef);
    private readonly localeId = inject@(Html.Raw("<string>"))(LOCALE_ID);
@if (Model.HasAnyAsyncValidators())
{
@:    private readonly asyncValidatorResolver = inject(ENTRY_ASYNC_VALIDATOR_RESOLVER, { optional: true });
}

    protected readonly form = new FormGroup({
@Html.AllFormControlDeclarations(Model)    });

@Html.AllArrayItemFactoryMethods(Model)
    constructor() {
        effect(() => {
            this.form.patchValue(this.model() as unknown as typeof this.form.value, { emitEvent: false });
        });
        effect(() => {
            if (this.isReadonly()) {
                this.form.disable({ emitEvent: false });
            } else {
                this.form.enable({ emitEvent: false });
@Html.ReEnableStaticReadonlyControls(Model)
            }
        });
    }

    protected readonly onSubmit = (): void => {
        if (this.form.valid) {
            this.save.emit(this.form.getRawValue() as I@(Model.ComponentInfo.ModelType));
        }
    };

    protected readonly isHidden = (propertyName: string, staticVisible: boolean): boolean => {
        if (!staticVisible) return true;
        return this.fieldsHideExpressions()?.[propertyName]?.(this.model()) ?? false;
    };

    protected readonly isDisabled = (propertyName: string, staticReadonly: boolean): boolean => {
        return this.isReadonly() || (this.fieldsDisableExpressions()?.[propertyName]
            ? this.fieldsDisableExpressions()![propertyName](this.model())
            : staticReadonly);
    };
}
