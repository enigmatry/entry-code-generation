@using Enigmatry.Entry.CodeGeneration
@using Enigmatry.Entry.CodeGeneration.Angular
@using Enigmatry.Entry.CodeGeneration.Configuration
@using Enigmatry.Entry.CodeGeneration.Configuration.Form.Controls
@using Enigmatry.Entry.CodeGeneration.Templates.HtmlHelperExtensions.Angular
@using Enigmatry.Entry.CodeGeneration.Templates.HtmlHelperExtensions.TypeScript
@model Enigmatry.Entry.CodeGeneration.Configuration.Form.FormComponentModel;
@inject CodeGeneratorOptions Options;

@functions {
    void InitializeSelectInputs()
    {
        foreach (var select in Model.FormControlsOfType<SelectControlBase>())
        {
            SelectInputOptions(select);
        }
    }

    void SelectInputOptions(SelectControlBase select)
    {
        if (select.Options.HasDynamicValues)
        {
            @:protected readonly @(select.PropertyName)Callback = input@(Html.Raw("<Observable<unknown[]>>"))([]);
            @:private readonly @(select.PropertyName)Options = toSignal(@(select.PropertyName)Callback, { initialValue: [] });
        }
        else
        {
            @:private readonly @(select.PropertyName)Options = toSignal(@Html.JsArray(select.Options.FixedOptions, option => $"{{ {option.GetValueExpression()}, displayName: {(@Html.Localize(option.DisplayName, Options.EnableI18N))} }}"), { initialValue: [] });
        }

        if (select.Options.HasCustomValueAndDisplayKeys)
        {
            @:protected readonly @(select.PropertyName)OptionsConfiguration = input@(Html.Raw("<SelectConfiguration>"))({ valueProperty: '@(select.Options.OptionValueKey)', labelProperty: '@(select.Options.OptionDisplayKey)', sortProperty: '@(select.Options.OptionSortKey)' });
        }
        else
        {
            @:protected readonly @(select.PropertyName)OptionsConfiguration = input@(Html.Raw("<SelectConfiguration>"))(Html.Raw(select.Options.DefaultOptionsAsString));
        }
    }
}

@@Component({
  selector: '@Model.AngularComponentSelector(Options.GeneratedComponentPrefix)',
  imports: [],
  templateUrl: './@(Model.AngularComponentFileName()).html',
  changeDetection: ChangeDetectionStrategy.OnPush
})
export class @Model.AngularComponentName() {
    protected readonly isReadonly = input@(Html.Raw("<boolean>"))(false);
    protected readonly model = model@(Html.Raw($"<I{Model.ComponentInfo.ModelType}>"))({} as I@(Model.ComponentInfo.ModelType));
    protected readonly saveButtonText = input@(Html.Raw("<string>"))('Save');
    protected readonly cancelButtonText = input@(Html.Raw("<string>"))('Cancel');
    protected readonly saveButtonDisabled = input@(Html.Raw("<boolean>"))(false);
    protected readonly formButtonsTemplate = input@(Html.Raw("<TemplateRef<unknown> | null | undefined>"))();

    protected readonly fieldsHideExpressions = input@(Html.Raw($"<I{Model.ComponentInfo.ModelType} | undefined>"))();
    protected readonly fieldsLabelExpressions = input@(Html.Raw($"<I{Model.ComponentInfo.ModelType} | undefined>"))();
    protected readonly fieldsPropertyExpressions = input@(Html.Raw($"<I{Model.ComponentInfo.ModelType} | undefined>"))();
    protected readonly fieldsDisableExpressions = input@(Html.Raw($"<I{Model.ComponentInfo.ModelType} | undefined>"))();
    protected readonly fieldsRequiredExpressions = input@(Html.Raw($"<I{Model.ComponentInfo.ModelType} | undefined>"))();

    @{
        InitializeSelectInputs();
    }

    protected readonly save = output@(Html.Raw($"<I{Model.ComponentInfo.ModelType}>"))();
    protected readonly cancel = output@(Html.Raw("<void>"))();
    protected readonly buttonClick = output@(Html.Raw("<string>"))();
    
    protected readonly form = new FormGroup({});
    protected readonly fields: FormlyFieldConfig[] = [];
     
    private readonly localeId = inject@(Html.Raw("<string>"))(LOCALE_ID);
    private readonly fieldTypeResolver = inject@(Html.Raw("<FieldTypeResolver>"))(ENTRY_FIELD_TYPE_RESOLVER, { optional: true });

    protected readonly onSubmit = () => {
        if (this.form.valid) {
            const throttledSave = toSignal(toObservable(this.save).pipe(throttleTime(500)));
            throttledSave(model);
        }
    };
    
    private readonly resolveFieldType = (type: string, isControlReadonly: boolean): string =>
        this.fieldTypeResolver ? this.fieldTypeResolver(type, this.isReadonly() || isControlReadonly) : type;

    private readonly applyOptionally = @(Html.Raw("<T>"))(value: T, apply: boolean): T | undefined => apply ? value : undefined;
}